{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
  "name": "io.github.kevin-buckley/vibe-sitecore",
  "description": "Minimal Vibe Sitecore MCP server exposing PowerShell tools plus a bundled migration skills manager.",
  "status": "active",
  "repository": {
    "url": "https://github.com/kevin-buckley/vibe-sitecore",
    "source": "github"
  },
  "version": "1.3.5",
  "packages": [
    {
      "registry_type": "npm",
      "registry_base_url": "https://registry.npmjs.org",
      "identifier": "vibe-sitecore",
      "version": "1.3.5",
      "transport": {
        "type": "stdio"
      },
      "environment_variables": [
        {
          "TRANSPORT": "stdio",
          "POWERSHELL_DOMAIN": "sitecore",
          "POWERSHELL_USERNAME": "admin",
          "POWERSHELL_PASSWORD": "b",
          "POWERSHELL_SERVER_URL": "https://example.com/",
          "AUTORIZATION_HEADER": "",
          "NODE_REJECT_UNAUTHORIZED": "0"
        }
      ]
    }
  ]
}